{
  "manifest_version": 3,
  "name": "Drift",
  "version": "1.0.1",
  "description": "A living landscape that reflects your day (i.e. calm focus brings clear skies, distraction brings storms).",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "idle",
    "storage",
    "alarms"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
